classes: {
  command: {
    style: {
      fill: "#ffff88"
    }
  }
  ai-effective-weak: {
    style: {
      fill: "#ffcccc"
    }
  }
  ai-effective: {
    style: {
      fill: "#ff8888"
    }
  }
  ai-effective-strong: {
    style: {
      fill: "#cc0000"
      stroke: "#990000"
      stroke-width: 2
    }
  }
}

development {
  label: "開発"
  frontend-development {
    label: "フロントエンド開発"

    ui-components {
      label: "UIコンポーネント"
      class: ai-effective-weak
      pages: "Pages\n(実際のページ)" { class: ai-effective }

    }
    api-client {
      label: "APIクライアント"
      grid-columns: 3
      class: ai-effective-weak
      "RESTクライアント" { class: ai-effective }
      "GraphQLクライアント" { class: ai-effective }
      "WebSocketクライアント" { class: ai-effective }
      "API通信のエラーハンドリング" { class: ai-effective }
      "API通信のリトライ・フォールバック" { class: ai-effective-weak }
      "ロギング/モニタリング" { class: ai-effective-weak }
    }

    ui-components <-> api-client: "サーバー側の呼び出し" 
    ui-components <-> api-client: "ブラウザ側の呼び出し" 
  }

  # バックエンド開発
  backend-development {
    label: "バックエンド開発"

    dto-development {
      label: "DTO開発"
      class: ai-effective
      grid-columns: 1
      dto-design: "DTO設計" { class: ai-effective }
      dto-implementation: "DTO実装" { class: ai-effective-strong }

      dto-design -> dto-implementation
    }

    backend {
      label: "バックエンド"
      
      api {
        label: "APIエンドポイント"
        class: ai-effective
        endpoints: "エンドポイント\n(REST/GraphQL)" { class: ai-effective-strong }
        validation: "入力バリデーション\n(リクエスト/レスポンス)" { class: ai-effective-strong }
      }
      service-definition {
        label: "サービス"
        class: ai-effective
      }
    }
  }

  # developmentの依存関係
  frontend-development.api-client <-> backend-development.dto-development
  backend-development.dto-development <-> backend-development.backend.api

  frontend-development.api-client -> backend-development.backend
}

"凡例": {
  label: "凡例"
  style: {
    fill: "#ffffff"
    stroke: "#000000"
    stroke-width: 0
  }
  grid-rows: 4
    command: "コマンド運用、またはバッチ処理(AIを用いない)" { class: command }
    ai-effective-weak: "AIに尋ねながら手作業するタスク(AI化するのは危険、または再現性が低い)" { class: ai-effective-weak }
    ai-effective: "AIへの数回の指示で完遂するタスク(再現性が高い)" { class: ai-effective }
    ai-effective-strong: "AIが確実に完遂できるタスク(再現性・効果が極めて高い)" { class: ai-effective-strong }
}

asis: |md
## 多くのプロジェクトにおけるAI以前の実装スタイル
- **フロントエンド固有ロジックのすべてが「手書き」**
  - APIクライアント / ブラウザ側アクセス制限の構築
  - リトライ・フォールバック / エラーハンドリング
  - ロギング・モニタリング / テストコード
- **重複・冗長な定義の実装**
  - 言語が異なる場合の DTO・バリデーションの再定義（手書き）

### 問題点
- 手書き中心の実装に起因する課題
  - 工数が大きい、バグの要因となりうる
  - バックエンドとフロントエンドの言語が異なる際の実装負荷が極めて大きい
|

asis.shape: page
asis.style: {
  fill: "#ffcccc"
}

tobe: |md
## 新たな実装スタイル
- **定義情報の活用**
  - CLAUDE.md : 実装指針（全プロジェクト共通）
  - specification.* : 連携仕様（リゾルバ・DTOの所在、言語設定、オプション等）
- **AIによる一括自動更新**
  - specification.* を変更後、AIが関連コードを一括更新
  - API連携からエラー管理まで、定義に基づきAIが同期

## AIが適切に実装できるタスク
- **AIによる自動生成と同期**
  - DTO（異言語時） / APIクライアント / アクセス経路の構築
- **共通機能の自動組み込み（Options）**
  - 出力バリデーション / リトライ・フォールバック
  - APIエラーハンドリング / ロギング・モニタリング
  - テストコード / 仕様書・コメントの出力

### AI駆動が解決する問題
- **大幅な工数削減** : 大半をAIが出力するため、フロントエンドの実装負荷を最小化
- **品質の安定** : 手作業によるバグ混入を排除し、堅牢な通信・エラー処理を保証
- **仕様変更への即時対応** : specification.* の変更をAIが即座に反映。常に最新の定義と同期
|

tobe.shape: page
tobe.style: {
  fill: "#ccffcc"
}

claude-md: |md
### CLAUDE.mdに記載する内容の要点
- バックエンドが公開しているすべてのAPIにアクセスできるAPIクライアントを作る
- ブラウザ側の呼び出しAPIのみ外部経路を作ること
  - サーバー内のみで使用しているAPIクライアントはブラウザから直接呼び出せない
- cookieをJWT Bearerに置き換えること
|

claude-md.shape: page
claude-md.style: {
  fill: "#ccffcc"
}


# 点線でつなぐ（吹き出しの引き出し線風）
development <-> asis: {
  style: {
    stroke-dash: 3
  }
}
development <-> tobe: {
  style: {
    stroke-dash: 3
  }
}
tobe -> claude-md
