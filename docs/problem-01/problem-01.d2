classes: {
  command: {
    style: {
      fill: "#ffff88"
    }
  }
  ai-effective-weak: {
    style: {
      fill: "#ffcccc"
    }
  }
  ai-effective: {
    style: {
      fill: "#ff8888"
    }
  }
  ai-effective-strong: {
    style: {
      fill: "#cc0000"
      stroke: "#990000"
      stroke-width: 2
    }
  }
}

development {
  label: "開発(AI活用の観点)"

  # バックエンド開発
  backend-development {
    label: "バックエンド開発"

    dto-development {
      label: "DTO開発"
      class: ai-effective
      grid-columns: 1
      dto-design: "DTO設計" { class: ai-effective }
      dto-implementation: "DTO実装" { class: ai-effective-strong }

      dto-design -> dto-implementation
    }

    backend {
      label: "バックエンド"
      
      api {
        label: "APIエンドポイント"
        class: ai-effective
        endpoints: "エンドポイント\n(REST/GraphQL)" { class: ai-effective-strong }
        validation: "入力バリデーション\n(リクエスト/レスポンス)" { class: ai-effective-strong }
      }
      service-definition {
        label: "サービス"
        grid-columns: 3
        class: ai-effective
        crud: "CRUD処理" { class: ai-effective-strong }
      }

      # 同階層の接続
      api -> service-definition
    }
    
    infrastructure {
      label: "インフラ"

      # 永続化グループ（DBアクセス関連）
      persistence {
        label: "データ永続化"
        db-access: {
          class: ai-effective
          label: "DBアクセス"
          orm: "ORMモデル定義\n(スキーマ記述)" { class: ai-effective-strong }
          db-migration: "DBマイグレーション" { class: command }
          sql-query: "SQLクエリ" { class: command }
          orm -> sql-query
          orm -> db-migration
        }
      }
    }
     
    # バックエンド内の依存関係
    backend.service-definition -> infrastructure.persistence.db-access
  }

  # developmentの依存関係
  frontend-development.api-client <-> backend-development.dto-development
  backend-development.dto-development <-> backend-development.backend.api

  frontend-development.api-client -> backend-development.backend
}

"凡例": {
  label: "凡例"
  style: {
    fill: "#ffffff"
    stroke: "#000000"
    stroke-width: 0
  }
  grid-rows: 4
    command: "コマンド運用、またはバッチ処理(AIを用いない)" { class: command }
    ai-effective: "AIへの数回の指示で完遂するタスク(再現性が高い)" { class: ai-effective }
    ai-effective-strong: "AIが確実に完遂できるタスク(再現性・効果が極めて高い)" { class: ai-effective-strong }
}

asis: |md
## 多くのプロジェクトにおけるAI以前の実装スタイル
- **主要な実装工程のすべてが「手書き」**
  - DTO / APIエンドポイント / 入力バリデーション
  - サービス / DBアクセス / ORM定義 / 単体テストコード
- **限定的な自動化（ORM依存）**
  - SQL生成 : ORMによる自動生成
  - DBマイグレーション : ORMが処理（複雑な変更のみ手書き）

### 問題点
- 手書き中心の実装に起因する課題
  - 工数が大きい、バグの要因となりうる
- 自動生成ライブラリの限界
  - 機能が固定され、CRUD以外の実装には柔軟性に欠ける
|

asis.shape: page
asis.style: {
  fill: "#ffcccc"
}

tobe: |md
## 新たな実装スタイル
- **定義情報の集約**
  - CLAUDE.md : 標準的な実装指針（全プロジェクト共通）
  - specification.* : データ構造（テーブル名、型、属性、リレーション）
- **AIによる自動実装**
  - 定義をもとに、DTOからORM定義までAIが一括実装
  - 仕様変更時もAIが差分を実装

## AIが適切に実装できるタスク
- **AIによる一貫した自動出力**
  - DTO / APIエンドポイント / 入力バリデーション
  - DBアクセス / ORM定義 / 単体テストコード
- **高度な判断を伴う実装の代行**
  - サービス : 構造に応じた典型的なロジックをAIが構築
  - SQL・マイグレーション : 複雑な変更やインデックス定義を実装
  - ドキュメント : 仕様書・コメントの自動記述

### AI駆動が解決する問題
- **圧倒的な効率化** : specification.* の定義からAIが大半を出力し、工数を大幅に削減
- **品質の安定** : 手作業によるバグ混入を排除し、一貫性のあるコードを生成
- **保守性の向上** : 変更箇所のみを specification.* に反映する最小変更アプローチ
|

tobe.shape: page
tobe.style: {
  fill: "#ccffcc"
}

claude-md: |md
### CLAUDE.mdに記載する内容の要点
- 使用するDB、ORM、APIの形態(REST/GraphQL)
- CreatedAt、UpdatedAtなどのタイムスタンプの扱いを自動化する
- IDの型を全体的に統一する(int,GUID,UUID,ULIDなど)
- テーブル内で使用できる属性について
  - ヒストリー型
  - 論理削除
    - 削除フラグ or 有効フラグ
  - カスケード削除
  - Upsert(既存レコードCreate時にはUpdateになる)
- 属性に応じた適切なIndexの自動生成のパターン
|

claude-md.shape: page
claude-md.style: {
  fill: "#ccffcc"
}


# 点線でつなぐ（吹き出しの引き出し線風）
development.backend-development <-> asis: {
  style: {
    stroke-dash: 3
  }
}
development.backend-development <-> tobe: {
  style: {
    stroke-dash: 3
  }
}
tobe -> claude-md
