classes: {
  command: {
    style: {
      fill: "#ffff88"
    }
  }
  ai-effective-weak: {
    style: {
      fill: "#ffcccc"
    }
  }
  ai-effective: {
    style: {
      fill: "#ff8888"
    }
  }
  ai-effective-strong: {
    style: {
      fill: "#cc0000"
      stroke: "#990000"
      stroke-width: 2
    }
  }
}

grid-columns: 2
development {
  label: "開発"
  grid-columns: 2

  request-development {
    label: "要求開発"
    
    requirement-collection {
      label: "要求収集"
      grid-columns: 3
      stakeholder-analysis {
        label: "ステークホルダー分析"
        identification: "ステークホルダーの特定"
        prioritization: "優先順位の決定"
        communication: "コミュニケーション計画"
        
        identification -> prioritization
        prioritization -> communication
      }
      interviews {
        label: "要件ヒアリング"
        user-interviews: "ユーザーインタビュー"
        expert-interviews: "専門家インタビュー"
        workshops: "ワークショップ"
        
        user-interviews -> expert-interviews
        expert-interviews -> workshops
      }
      surveys {
        label: "アンケート調査"
        online-surveys: "オンラインアンケート"
        feedback-collection: "フィードバック収集"
        analysis: "アンケート結果の分析" { class: ai-effective-strong }
        
        online-surveys -> feedback-collection
        feedback-collection -> analysis
      }
      document-review: "ドキュメントレビュー"
      observation: "観察・フィールドスタディ"
      
      stakeholder-analysis -> interviews
      interviews -> surveys
      surveys -> document-review
      document-review -> observation
    }
    
    requirement-definition {
      label: "要件定義"
      grid-columns: 3
      functional {
        label: "機能要件"
        grid-columns: 3
        user-stories: "ユーザーストーリー"
        features: "機能一覧" { class: ai-effective }
        screen-transitions: "画面遷移・ナビゲーション" { class: ai-effective-weak }
        ui-ux-requirements: "UI/UX要件・デザインコンセプト"
        interaction-design: "インタラクション設計\n(状態変化・フィードバック)" { class: ai-effective-weak }
        business-rules: "業務ルール"
        data-flow: "データフロー"
        api-requirements: "API要件" { class: ai-effective }
        validation: "入力・出力検証"
        error-handling: "エラー処理"
        reporting: "レポート機能"
        accessibility: "アクセシビリティ要件"
      }
      non-functional {
        label: "非機能要件"
        performance: "性能要件"
        security: "セキュリティ要件"
        usability: "ユーザビリティ"
        scalability: "スケーラビリティ"
        
        performance -> security
        security -> usability
        usability -> scalability
      }
      prioritization {
        label: "優先順位の決定"
        moscow: "MoSCoW法"
        criteria: "評価基準"
        ranking: "ランキング"
        
        moscow -> criteria
        criteria -> ranking
      }
      
      functional -> non-functional
      non-functional -> prioritization
    }
    
    specification {
      label: "仕様定義"
      grid-columns: 3

      use-cases: "ユースケース" { class: ai-effective-weak }
      screen-def: "画面詳細仕様\n(レイアウト・入力項目定義)" { class: ai-effective-weak }
      api-contract: "APIコントラクト\n(インターフェース定義)" { class: ai-effective-weak }

      detailed-spec {
        label: "詳細仕様"
        class: ai-effective-weak

        ui-behavior: "UI制御・フロントエンド状態遷移" { class: ai-effective-weak }
        business-logic: "業務ロジック・ドメインルール"

        logging {
          label: "ログ・監視基準"
          class: ai-effective-weak
          events: "イベントの記録" { class: ai-effective-weak }
          retention: "保持期間・アーカイブ"
        }

        error-management {
          label: "例外・エラー制御"
          class: ai-effective-weak
          fallback: "再試行・フォールバック" { class: ai-effective-weak }
          messages: "メッセージの定義(ユーザー通知・多言語)" { class: ai-effective-weak }
        }

        ui-behavior -> business-logic
        logging -> error-management
      }

      use-cases -> screen-def
      screen-def -> api-contract
      api-contract -> detailed-spec
    }
    
    validation {
      label: "検証"
      review: "要件のレビュー" { class: ai-effective }
      approval: "合意形成"
      
      review -> approval
    }

    request-management {
      label: "要求管理"
      tracking: "要求の追跡" { class: ai-effective }
      prioritization: "優先順位の管理" { class: ai-effective }
      change-control: "変更の管理" { class: ai-effective-weak }
      
      tracking -> prioritization
      prioritization -> change-control
    }
    

    # request-development内の接続
    requirement-collection -> requirement-definition
    requirement-definition -> specification
    request-management -> requirement-definition
    requirement-collection -> request-management
    requirement-collection <- request-management
    specification -> validation
  }

  frontend-development {
    label: "フロントエンド開発"
    design {
      label: "デザイン"
      info_arch {
        label: "情報アーキテクチャ"
        class: ai-effective-weak
        "サイト構造設計" { class: ai-effective-weak }
        "ナビゲーション設計" { class: ai-effective-weak }
        "コンテンツ整理"
      }
      prototyping: { 
        label: "プロトタイピング"
        class: ai-effective
        "ワイヤーフレーム" { class: ai-effective }
        mockup {
          label: "モック作成"
          class: ai-effective
          "静的モック" { class: ai-effective }
          "インタラクティブモック" { class: ai-effective }
        }
      }
      style-guide: "スタイルガイド" { class: ai-effective }

      # design内の接続
      info_arch -> prototyping
      prototyping -> style-guide
      style-guide -> "ユーザビリティテスト"
    }

    frontend {
      label: "フロントエンド"
      ui-components {
        label: "UIコンポーネント"
        class: ai-effective-weak
        grid-columns: 3
        atoms: "Atoms\n(ボタン、入力フィールドなど)" { class: ai-effective }
        molecules: "Molecules\n(検索フォーム、カードなど)" { class: ai-effective }
        organisms: "Organisms\n(ヘッダー、ナビゲーションなど)" { class: ai-effective }
        templates: "Templates\n(ページレイアウト)" { class: ai-effective }
        pages: "Pages\n(実際のページ)" { class: ai-effective }

        # ui-components内の接続
        atoms -> molecules
        molecules -> organisms
        organisms -> templates
        templates -> pages
      }
      state-management {
        label: "状態管理"
        class: ai-effective-weak
        grid-columns: 3
        local-state: "ローカル状態の管理" { class: ai-effective-weak }
        global-state: "グローバル状態の管理" { class: ai-effective-weak }
        server-state: "サーバー状態の管理" { class: ai-effective-weak }
      }
      routing {
        label: "ルーティング"
        grid-columns: 1
        class: ai-effective-weak
        "ルート定義" { class: ai-effective-weak }
      }
      ui-test: {
        label: "UIテスト"
        class: ai-effective-weak
        grid-columns: 3
        "Playwright自動テスト" { class: ai-effective-weak }
        "コンポーネントテスト" { class: ai-effective-weak }
        "スナップショットテスト" { class: ai-effective-weak }
      }

      # 同階層の接続
      ui-components -> state-management
      state-management -> routing
    }

    api-client {
      label: "APIクライアント"
      grid-columns: 3
      class: ai-effective-weak
      "RESTクライアント" { class: ai-effective }
      "GraphQLクライアント" { class: ai-effective }
      "WebSocketクライアント" { class: ai-effective }
      "API通信のエラーハンドリング" { class: ai-effective }
      "API通信のリトライ・フォールバック" { class: ai-effective-weak }
      "ロギング/モニタリング" { class: ai-effective-weak }
    }

    testing: {
      label: "テスト"
      class: ai-effective-weak
      grid-columns: 4
      "単体テスト" { class: ai-effective }
      "ユーザーフローのE2Eテスト" { class: ai-effective-weak }
      "API連携のE2Eテスト" { class: ai-effective-weak }
      "クロスブラウザテスト" { class: ai-effective-weak }
    }
    cicd: "CI/CD" { class: ai-effective-weak }
    frontend-build: "フロントエンドビルド" { class: command }
    frontend-deploy: "開発環境（フロントエンド）デプロイ" { class: command }

    # フロントエンド内の依存関係
    design -> frontend
    frontend.ui-components -> api-client
    frontend -> cicd
    api-client -> testing
    cicd -> frontend-build
    frontend-build -> testing
    testing -> frontend-deploy
  }

  # バックエンド開発
  backend-development {
    label: "バックエンド開発"

    dto-development {
      label: "DTO開発"
      class: ai-effective
      grid-columns: 1
      dto-design: "DTO設計" { class: ai-effective }
      dto-implementation: "DTO実装" { class: ai-effective-strong }

      dto-design -> dto-implementation
    }

    backend {
      label: "バックエンド"
      
      auth {
        label: "認証/認可"
        class: ai-effective-weak
        grid-columns: 2
        "ユーザ管理" { class: ai-effective }
        "セッション管理\n(REST-APIでは不要)" { class: ai-effective }
        "権限管理" { class: ai-effective }
        "OAuth実装" { class: ai-effective-weak }
      }
      api {
        label: "APIエンドポイント"
        class: ai-effective
        endpoints: "エンドポイント\n(REST/GraphQL)" { class: ai-effective-strong }
        validation: "入力バリデーション\n(リクエスト/レスポンス)" { class: ai-effective-strong }
      }
      service-definition {
        label: "サービス"
        grid-columns: 3
        class: ai-effective
        domain-model: "ドメインモデル定義" { class: ai-effective }
        "ビジネスルール" { class: ai-effective }
        "計算ロジック" { class: ai-effective }
        "ワークフロー管理" { class: ai-effective }
        "基盤クラス作成" { class: ai-effective-weak }
        log-output: "ログ出力" { class: ai-effective }
        crud: "CRUD処理" { class: ai-effective-strong }
      }

      # 同階層の接続
      auth -> api
      api -> service-definition
      api.endpoints -> api.validation
    }
    
    testing {
      label: "テスト"
      class: ai-effective
      grid-columns: 3
      unit: "単体テスト" { class: ai-effective }
      integration: "結合テスト" { class: ai-effective-weak }
      contract: "契約テスト" { class: ai-effective-weak }
    }
    cicd: "CI/CD" { class: ai-effective-weak }
    backend-deploy: "開発環境（バックエンド）デプロイ" { class: command }
    backend-build: "バックエンドビルド" { class: command }

    infrastructure {
      label: "インフラ"

      # 永続化グループ（DBアクセス関連）
      persistence {
        label: "データ永続化"
        file-storage: "ファイルストレージ" { class: command }
        db-access: {
          class: ai-effective
          label: "DBアクセス"
          orm: "ORMモデル定義\n(スキーマ記述)" { class: ai-effective-strong }
          db-migration: "DBマイグレーション" { class: command }
          sql-query: "SQLクエリ" { class: command }
          transaction: "トランザクション管理" { class: ai-effective-weak }

          orm -> sql-query
          orm -> db-migration
        }
      }

      iac: "IaC\n(Infrastructure as Code)" { class: ai-effective }
      deployment: "本番環境デプロイ" { class: command }
      cloud-provider: "クラウドプロバイダ" { class: command }
      server-management: "サーバー管理" { class: command }
      container-orchestration: "コンテナオーケストレーション" { class: command }
      scaling: "スケーリング" { class: command }
      db-management: "DB管理" { class: command }
      backup-restore: "バックアップ/リストア" { class: command }
      db: "データベース" { class: command }
    
      iac -> deployment
      deployment -> cloud-provider
      cloud-provider -> db
      cloud-provider -> server-management
      cloud-provider -> container-orchestration
      cloud-provider -> persistence.file-storage
      server-management -> scaling
      container-orchestration -> scaling
      db -> db-management
      db-management -> backup-restore
    }
 
    security-review {
      label: "セキュリティレビュー"
      class: ai-effective
    }
    backend.auth -> security-review
    backend.api -> security-review
    infrastructure -> security-review
    
    # バックエンド内の依存関係
    backend.service-definition -> infrastructure.persistence.db-access
    backend.service-definition -> cicd
    backend-build -> testing
    cicd -> backend-build
    testing -> backend-deploy
    infrastructure.persistence.db-access -> infrastructure.persistence.db-details
    infrastructure.persistence -> infrastructure.db
  }

  # developmentの依存関係
  frontend-development.api-client <-> backend-development.dto-development
  backend-development.dto-development <-> backend-development.backend.api
  request-development -> frontend-development
  request-development -> backend-development

  frontend-development.design.prototyping -> request-development.requirement-definition
  frontend-development.api-client -> backend-development.backend
}

ops {
  label: "運用/保守"
  
  monitoring {
    label: "監視"
    class: command
    system: "システム監視"
    application: "アプリケーションモニタリング"
    performance: "パフォーマンス監視" { class: ai-effective-weak }
    
    system -> application
    application -> performance
  }
  
  logging {
    label: "ログ管理"
    collection: "ログ収集" { class: command }
    analysis: "ログ分析" { class: ai-effective }
    storage: "ログ保管" { class: command }
    
    collection -> analysis
    analysis -> storage
  }
  
  incident {
    label: "障害対応"
    management: "インシデント管理" { class: command }
    recovery: "復旧手順" { class: ai-effective-weak }
    postmortem: "ポストモーテム" { class: ai-effective-weak }
    
    management -> recovery
    recovery -> postmortem
  }
  
  backup {
    label: "バックアップ"
    class: command
    data: "データバックアップ"
    test: "リストアテスト"
    
    data -> test
  }
  
  security {
    label: "セキュリティ運用"
    patches: "パッチ管理" { class: command }
    scans: "脆弱性スキャン" { class: ai-effective-weak }
    
    scans -> patches
  }
  
  scaling {
    label: "スケーリング"
    class: command
    auto: "自動スケーリング"
    planning: "容量計画" { class: ai-effective-weak }
    
    auto -> planning
  }
  
  maintenance {
    label: "メンテナンス"
    class: command
    regular: "定期メンテナンス"
    updates: "アップデート"
    
    regular -> updates
  }
  
  feedback {
    label: "ユーザー統計 & フィードバック"
    user_stats: "ユーザー使用統計収集" { class: command }
    analysis: "統計分析" { class: ai-effective-weak }
    dev_feedback: "開発フィードバック"
    
    user_stats -> analysis
    analysis -> dev_feedback
  }
  
  # ops内の依存関係
  monitoring -> incident.management
  logging -> monitoring.system
  backup -> incident.recovery
  security -> maintenance.regular
  scaling -> monitoring.performance
  monitoring.application -> feedback.user_stats
  logging.analysis -> feedback.user_stats
}

"凡例": {
  label: "凡例"
  style: {
    fill: "#ffffff"
    stroke: "#000000"
    stroke-width: 0
  }
  grid-rows: 4
    command: "コマンド運用、またはバッチ処理(AIを用いない)" { class: command }
    ai-effective-weak: "AIに尋ねながら手作業するタスク(AI化するのは危険、または再現性が低い)" { class: ai-effective-weak }
    ai-effective: "AIに指示を数回与えることで実現できるタスク(再現性が高い)" { class: ai-effective }
    ai-effective-strong: "AIが確実に完遂できるタスク(再現性・効果が極めて高い)" { class: ai-effective-strong }
}
# development -> ops
# ops.feedback.dev_feedback -> development.request-development.request-management.tracking
# development.backend-development.backend.service-definition -> ops.logging.collection
