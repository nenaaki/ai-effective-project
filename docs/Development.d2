classes: {
  command: {
    style: {
      fill: "#ffff88"
    }
  }
  ai-effective-weak: {
    style: {
      fill: "#ffcccc"
    }
  }
  ai-effective: {
    style: {
      fill: "#ff8888"
    }
  }
  ai-effective-strong: {
    style: {
      fill: "#cc0000"
      stroke: "#990000"
      stroke-width: 2
    }
  }
}

customer: {
  shape: person
  label: "顧客"
}

user: {
  shape: person
  label: "ユーザー"
}

operator: {
  shape: person
  label: "運用担当者"
}

development {
  request-development {
    label: "要求開発"
    
    requirement-collection {
      label: "要求収集"
      grid-columns: 3
      stakeholder-analysis {
        label: "ステークホルダー分析"
        identification: "ステークホルダー識別"
        prioritization: "優先順位付け"
        communication: "コミュニケーション計画"
        
        identification -> prioritization
        prioritization -> communication
      }
      interviews {
        label: "要件ヒアリング"
        user-interviews: "ユーザーインタビュー"
        expert-interviews: "専門家インタビュー"
        workshops: "ワークショップ"
        
        user-interviews -> expert-interviews
        expert-interviews -> workshops
      }
      surveys {
        label: "アンケート調査"
        online-surveys: "オンラインアンケート"
        feedback-collection: "フィードバック収集"
        analysis: "アンケート分析" { class: ai-effective-strong }
        
        online-surveys -> feedback-collection
        feedback-collection -> analysis
      }
      document-review: "ドキュメントレビュー"
      observation: "観察・フィールドスタディ"
      
      stakeholder-analysis -> interviews
      interviews -> surveys
      surveys -> document-review
      document-review -> observation
    }
    
    requirement-definition {
      label: "要件定義"
      grid-columns: 3
      functional {
        label: "機能要件"
        user-stories: "ユーザーストーリー" { class: ai-effective }
        features: "機能一覧" { class: ai-effective }
        business-rules: "業務ルール" { class: ai-effective }
        data-flow: "データフロー" { class: ai-effective }
        api-requirements: "API要件" { class: ai-effective }
        validation: "入力・出力検証"
        error-handling: "エラー処理"
        reporting: "レポート機能"

        user-stories -> features
        features -> business-rules
        business-rules -> validation
        validation -> error-handling
        error-handling -> reporting
        reporting -> api-requirements
      }
      non-functional {
        label: "非機能要件"
        performance: "性能要件"
        security: "セキュリティ要件"
        usability: "ユーザビリティ"
        scalability: "スケーラビリティ"
        
        performance -> security
        security -> usability
        usability -> scalability
      }
      prioritization {
        label: "優先順位付け"
        moscow: "MoSCoW法"
        criteria: "評価基準"
        ranking: "ランキング"
        
        moscow -> criteria
        criteria -> ranking
      }
      
      functional -> non-functional
      non-functional -> prioritization
    }
    
    specification {
      label: "仕様定義"
      grid-columns: 3
      use-cases: "ユースケース" { class: ai-effective-strong }
      system-req: "システム要件" { class: ai-effective }
      detailed-spec {
        label: "詳細仕様"
        class: ai-effective
        logging-requirements: "ログ基準"
        logging-events: "記録対象イベント(成功/失敗/例外)"
        logging-format: "フォーマット(CSV/JSON/構造化)"
        logging-retention: "保持期間・アーカイブ"

        exception-handling: "例外処理"
        business-exceptions: "ビジネス例外(バリデーション、業務ルール違反)"
        retry-policy: "再試行・フォールバック"
        log-alerts: "ログ連携アラート条件"

        logging-requirements -> logging-events
        logging-events -> logging-format
        logging-format -> logging-retention
        business-exceptions -> retry-policy
        business-exceptions -> log-alerts
      }
      
      use-cases -> system-req
      system-req -> detailed-spec
    }
    
    validation {
      label: "検証"
      review: "要件レビュー" { class: ai-effective }
      approval: "合意形成"
      
      review -> approval
    }

    request-management {
      label: "要求管理"
      tracking: "要求追跡" { class: command }
      prioritization: "優先順位管理" { class: command }
      change-control: "変更管理" { class: command }
      
      tracking -> prioritization
      prioritization -> change-control
    }
    

    # request-development内の接続
    requirement-collection -> requirement-definition
    requirement-definition -> specification
    requirement-definition <-> request-management
    specification -> validation
  }

  dto-development {
    label: "DTO開発"
    class: ai-effective
    dto-design: "DTO設計" { class: ai-effective }
    dto-implementation: "DTO実装" { class: ai-effective-strong }

    dto-design -> dto-implementation
  }
  frontend-development.api-client -> dto-development
  backend-development.backend.api -> dto-development

  frontend-development {
    label: "フロントエンド開発"
    frontend {
      label: "フロントエンド"
      design {
          label: "デザイン"
          info_arch {
            label: "情報アーキテクチャ"
            class: ai-effective
            "サイト構造設計"
            "ナビゲーション設計"
            "コンテンツ整理"
          }
          prototyping: { 
            label: "プロトタイピング"
            class: ai-effective
            "ワイヤーフレーム"
            mockup {
              label: "モック作成"
              class: ai-effective-weak
              "静的モック" { class: ai-effective }
              "インタラクティブモック" { class: ai-effective }
            }
          }
          style-guide: "スタイルガイド" { class: ai-effective }

          # design内の接続
          info_arch -> prototyping
          prototyping -> style-guide
          style-guide -> "ユーザビリティテスト"
      }
      ui-components {
        label: "UIコンポーネント"
        grid-columns: 3
        atoms: "Atoms\n(ボタン、入力フィールドなど)" { class: ai-effective }
        molecules: "Molecules\n(検索フォーム、カードなど)" { class: ai-effective }
        organisms: "Organisms\n(ヘッダー、ナビゲーションなど)" { class: ai-effective }
        templates: "Templates\n(ページレイアウト)" { class: ai-effective }
        pages: "Pages\n(実際のページ)" { class: ai-effective }

        # ui-components内の接続
        atoms -> molecules
        molecules -> organisms
        organisms -> templates
        templates -> pages
      }
      state-management {
        label: "状態管理"
        class: ai-effective-weak
        grid-columns: 3
        "ローカル状態管理" { class: ai-effective-weak }
        "グローバル状態管理" { class: ai-effective-weak }
        server-state: "サーバー状態管理" { class: ai-effective-weak }
      }
      routing {
        label: "ルーティング"
        class: ai-effective-weak
        "ルート定義" { class: ai-effective-weak }
      }

      # 同階層の接続
      design -> ui-components
      ui-components -> state-management
      state-management -> routing
    }
    api-client {
      label: "APIクライアント"
      grid-columns: 3
      class: ai-effective
      "RESTクライアント" { class: ai-effective }
      "GraphQLクライアント" { class: ai-effective }
      "WebSocketクライアント" { class: ai-effective }
    }

    "フロントエンドテスト" { class: ai-effective }
    "E2Eテスト" { class: ai-effective }
    "CI/CD" { class: ai-effective }
    "フロントエンドビルド" { class: command }
    "開発環境（フロントエンド）デプロイ" { class: command }

    # フロントエンド内の依存関係
    frontend.ui-components -> api-client
    frontend -> "フロントエンドテスト"
    api-client -> "E2Eテスト"
    "フロントエンドテスト" -> "CI/CD"
    "CI/CD" -> "フロントエンドビルド"
    "CI/CD" -> "開発環境（フロントエンド）デプロイ"
  }

  # バックエンド開発
  backend-development {
    label: "バックエンド開発"
    
    backend {
      label: "バックエンド"
      
      auth {
        label: "認証/認可"
        class: ai-effective
        grid-columns: 2
        "ユーザ管理" { class: ai-effective }
        "セッション管理" { class: ai-effective }
        "権限管理" { class: ai-effective }
        "OAuth実装" { class: ai-effective }
      }
      api {
        label: "APIエンドポイント"
        class: ai-effective
        endpoints: "エンドポイント\n(REST/GraphQL)" { class: ai-effective-strong }
        validation: "入力バリデーション\n(リクエスト/レスポンス)" { class: ai-effective-strong }
      }
      service-definition {
        label: "サービス"
        grid-columns: 3
        class: ai-effective
        domain-model: "ドメインモデル定義" { class: ai-effective }
        "ビジネスルール" { class: ai-effective }
        "計算ロジック" { class: ai-effective }
        "ワークフロー管理" { class: ai-effective }
        "基盤クラス作成" { class: ai-effective-weak }
        log-output: "ログ出力" { class: ai-effective }
      }
      "単体テスト" { class: ai-effective }

      # 同階層の接続
      auth -> api
      api -> service-definition
      service-definition -> "単体テスト"
      api.endpoints -> api.validation
    }
    
    backend-test: "バックエンドテスト" { class: ai-effective }
    ci: "CI/CD" { class: ai-effective }
    deploy: "開発環境（バックエンド）デプロイ" { class: command }
    "バックエンドビルド" { class: command }

    infrastructure {
      label: "インフラ"

      # 永続化グループ（DBアクセス関連）
      persistence {
        label: "データ永続化"
        file-storage: "ファイルストレージ" { class: command }
        db-access: "DBアクセス" { class: ai-effective }
        db-details {
          class: ai-effective
          label: "DBアクセス詳細"
          orm: "ORMモデル定義\n(スキーマ記述)" { class: ai-effective }
          db-migration: "DBマイグレーション" { class: command }
          sql-query: "SQLクエリ" { class: ai-effective }
          transaction: "トランザクション管理" { class: ai-effective-weak }

          orm -> sql-query
          orm -> db-migration
        }
      }

      iac: "IaC\n(Infrastructure as Code)" { class: ai-effective }
      deployment: "本番環境デプロイ" { class: command }
      cloud-provider: "クラウドプロバイダ" { class: command }
      server-management: "サーバー管理" { class: command }
      container-orchestration: "コンテナオーケストレーション" { class: command }
      scaling: "スケーリング" { class: command }
      db-management: "DB管理" { class: command }
      backup-restore: "バックアップ/リストア" { class: command }
      db: "データベース" { class: command }
    
      iac -> deployment
      deployment -> cloud-provider
      cloud-provider -> db
      cloud-provider -> server-management
      cloud-provider -> container-orchestration
      cloud-provider -> persistence.file-storage
      server-management -> scaling
      container-orchestration -> scaling
      db -> db-management
      db-management -> backup-restore
    }
 
    security-review {
      label: "セキュリティレビュー"
      class: ai-effective
    }
    backend.auth -> security-review
    backend.api -> security-review
    infrastructure -> security-review
    
    # バックエンド内の依存関係
    backend.service-definition -> infrastructure.persistence.db-access
    backend.service-definition -> backend-test
    backend-test -> ci
    ci -> deploy
    ci -> "バックエンドビルド"
    infrastructure.persistence.db-access -> infrastructure.persistence.db-details
    infrastructure.persistence -> infrastructure.db
  }

  # 全体の依存関係
  request-development.requirement-definition -> frontend-development.frontend.design.info_arch
  request-development.specification -> backend-development.backend
  frontend-development.frontend.design.prototyping -> request-development.requirement-definition
  frontend-development.api-client -> backend-development.backend
}

ops {
  label: "運用/保守"
  
  monitoring {
    label: "監視"
    class: command
    system: "システム監視"
    application: "アプリケーションモニタリング"
    performance: "パフォーマンス監視" { class: ai-effective }
    
    system -> application
    application -> performance
  }
  
  logging {
    label: "ログ管理"
    collection: "ログ収集" { class: command }
    analysis: "ログ分析" { class: ai-effective }
    storage: "ログ保管" { class: command }
    
    collection -> analysis
    analysis -> storage
  }
  
  incident {
    label: "障害対応"
    management: "インシデント管理" { class: command }
    recovery: "復旧手順" { class: ai-effective }
    postmortem: "ポストモーテム" { class: ai-effective }
    
    management -> recovery
    recovery -> postmortem
  }
  
  backup {
    label: "バックアップ"
    class: command
    data: "データバックアップ"
    test: "リストアテスト" { class: ai-effective }
    
    data -> test
  }
  
  security {
    label: "セキュリティ運用"
    patches: "パッチ管理" { class: command }
    scans: "脆弱性スキャン" { class: ai-effective }
    
    scans -> patches
  }
  
  scaling {
    label: "スケーリング"
    class: command
    auto: "自動スケーリング"
    planning: "容量計画" { class: ai-effective }
    
    auto -> planning
  }
  
  maintenance {
    label: "メンテナンス"
    class: command
    regular: "定期メンテナンス"
    updates: "アップデート" { class: ai-effective }
    
    regular -> updates
  }
  
  feedback {
    label: "ユーザー統計 & フィードバック"
    user_stats: "ユーザー使用統計収集" { class: command }
    analysis: "統計分析" { class: ai-effective }
    dev_feedback: "開発フィードバック"
    
    user_stats -> analysis
    analysis -> dev_feedback
  }
  
  # ops内の依存関係
  monitoring -> incident.management
  logging -> monitoring.system
  backup -> incident.recovery
  security -> maintenance.regular
  scaling -> monitoring.performance
  monitoring.application -> feedback.user_stats
  logging.analysis -> feedback.user_stats
}

development -> ops
ops.feedback.dev_feedback -> development.request-development.request-management.tracking
development.backend-development.backend.service-definition -> ops.logging.collection

